{
  "name": "brokerapp",
  "version": "1.0.0",
  "description": "",
  "main": "main.js",
  "scripts": {
    "test": "python3 -m unittest discover -s tests -p \"test_*.py\"",
    "start": "electron .",
    "setup:python": "python3 -m venv .venv && ./.venv/bin/python -m pip install --upgrade pip && ./.venv/bin/python -m pip install -r requirements.txt",
    "setup:python:win": "py -3 -m venv .venv && .\\.venv\\Scripts\\python -m pip install --upgrade pip && .\\.venv\\Scripts\\python -m pip install -r requirements.txt",
    "build:backend": "./.venv/bin/python -m PyInstaller --noconfirm --clean --onefile --name broker-backend script.py",
    "build:backend:win": ".\\.venv\\Scripts\\python -m PyInstaller --noconfirm --clean --onefile --name broker-backend script.py",
    "build:desktop": "npm run build:backend && electron-builder --win",
    "build:desktop:win": "npm run build:backend:win && electron-builder --win",
    "build:linux": "npm run build:backend && electron-builder --linux AppImage"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^40.6.1",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.brokerapp.desktop",
    "productName": "BrokerApp",
    "asar": true,
    "files": [
      "**/*",
      "!dist/**",
      "!build/**",
      "!tests/**",
      "!*.py",
      "!*.spec",
      "!credentials*.json",
      "!token*.json"
    ],
    "extraResources": [
      {
        "from": "dist",
        "to": "backend",
        "filter": [
          "broker-backend*"
        ]
      }
    ],
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Utility"
    }
  }
}
